theme = dark:van-helsing, light:alucard
# theme = dark:van-helsing, light:van-helsing
#theme = dark:Kanagawa Dragon, light:Kanagawa Dragon
#theme = dark:Kanso Ink, light:Kanso Ink
#theme = dark:Catppuccin Mocha, light: Catppuccin Latte
cursor-style = block
cursor-style-blink = true
background-opacity = 0.8
background-blur= true
background-blur-radius = 20
#background-image = /Users/dongjunkim/.config/ghostty/wallpapers/macos-monterey-stock-black-dark-mode-layers-5k-3840x2160-5889.jpg
