# Ignore everything
*

# Always ignore these
.DS_Store
*.swp
*.swo

# Secrets — never commit. Redundant with `*` above but explicit for safety.
secrets/
secrets/**

# Except dotfiles repo files
!.gitignore
!setup.sh
!Brewfile

# Shell
!.zshrc
!zsh/
!zsh/**

# Git
!git/
!git/**

# Neovim
!nvim/
!nvim/**

# Terminal
!ghostty/
!ghostty/config
!ghostty/themes/
!ghostty/themes/**

# Tmux
!tmux/
!tmux/tmux.conf

# Starship
!starship.toml

# Atuin
!atuin/
!atuin/config.toml

# Re-deny noise that whitelisted directories above accidentally re-include
**/.omc/
**/.DS_Store
