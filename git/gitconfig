[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[color]
  ui = auto

[color "branch"]
  current = bold green
  local = white
  remote = bold red

[color "status"]
  added = green
  changed = yellow
  untracked = red

[color "diff"]
  meta = bold magenta
  frag = cyan
  old = red
  new = green

[color "decorate"]
  branch = bold cyan
  remoteBranch = bold yellow
  tag = bold magenta
  HEAD = bold white

[core]
  editor = nvim

[commit]
  gpgSign = false

[tag]
  forceSignAnnotated = false
